{
  "name": "afriflow",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:migrate": "turbo run db:migrate --filter=@afriflow/db",
    "db:generate": "turbo run db:generate --filter=@afriflow/db"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.0",
    "prettier": "^3.3.0",
    "@types/node": "^20.14.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
