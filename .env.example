# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/afriflow
REDIS_URL=redis://localhost:6379

# Auth — générer avec: openssl rand -base64 64
JWT_SECRET=change_me_256_bit_random_secret

# Email
RESEND_API_KEY=re_xxxxxxxx

# SMS — configuré via l'API admin : PATCH /api/v1/settings/sms
# Providers disponibles : twilio | africas_talking | orange | infobip | termii | http_webhook
# Les credentials sont stockés dans tenant.settings (pas de variables d'env nécessaires)

# WhatsApp
WATI_BASE_URL=https://live-mt-server.wati.io/xxxxx
WATI_TOKEN=xxxxxxxx

# Paiements
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
PAYSTACK_WEBHOOK_SECRET=xxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=xxxxxxxx
WAVE_API_KEY=xxxxxxxx
WAVE_WEBHOOK_SECRET=xxxxxxxx

# IA
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Stockage Cloudflare R2
CLOUDFLARE_R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=xxxxxxxx
CLOUDFLARE_R2_SECRET_KEY=xxxxxxxx
R2_BUCKET_NAME=afriflow-media

# Monitoring
SENTRY_DSN=https://xxx@sentry.io/xxx
POSTHOG_API_KEY=phc_xxxxxxxx

# App
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
