# Image minimale pour le runner de migrations
# Build context : racine du monorepo
FROM node:22-alpine

WORKDIR /app

# Installer uniquement le client postgres (même version que le projet)
RUN npm install postgres@^3.4.4 --no-save

# Copier le script de migration
COPY infra/migrate.mjs ./migrate.mjs

# Copier les fichiers SQL de migration
COPY packages/db/src/migrations ./packages/db/src/migrations/

ENV NODE_ENV=production

CMD ["node", "migrate.mjs"]
